# інший текст у кінці поста (за замовчуванням — рядок з @ua_goroskop)
# HOROSCOPE_POST_FOOTER=🔮 ...\n👉 @channel
# часовий пояс для дати на картинці та в промпті (IANA), за замовчуванням Europe/Kyiv
# HOROSCOPE_TZ=Europe/Kyiv
