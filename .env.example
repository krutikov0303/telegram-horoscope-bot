GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# uk або ru
HOROSCOPE_LANG=uk
# опційно: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash (див. доку Google)
# GEMINI_MODEL=gemini-2.5-flash
# без картинки-обкладинки перед текстом
# HOROSCOPE_SKIP_COVER=1
# стиль обкладинки: emerald_noir (за замовчуванням) або soft_beige
# HOROSCOPE_COVER_STYLE=emerald_noir
# інший текст у кінці поста (за замовчуванням — рядок з @goroskop_dnya_ua)
# HOROSCOPE_POST_FOOTER=🔮 ...\n👉 @channel
# часовий пояс для дати на картинці та в промпті (IANA), за замовчуванням Europe/Kyiv
# HOROSCOPE_TZ=Europe/Kyiv
# лише для CI: тип події (schedule / workflow_dispatch)
# GITHUB_EVENT_NAME=workflow_dispatch
# повторно опублікувати в той самий день (ігнор дедупу для schedule)
# HOROSCOPE_FORCE_POST=1
